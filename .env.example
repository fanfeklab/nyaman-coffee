# ========================================
# 🚀 SUPABASE CONFIGURATION (REQUIRED)
# ========================================

# Public URL - Get from: Supabase Dashboard > Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Public API Key (anon) - Get from: Supabase Dashboard > Settings > API > Project API Keys > anon (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Private API Key (service_role) - Get from: Supabase Dashboard > Settings > API > Project API Keys > service_role (secret)
# ⚠️ SENSITIVE! NEVER share or commit to Git!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Database Connection URL - Get from: Supabase Dashboard > Settings > Database > Connection Pooler > Session pool
# Format: postgresql://postgres.xxxx:password@aws-0-xxxxx.pooler.supabase.com:6543/postgres
# ⚠️ SENSITIVE! NEVER share or commit to Git!
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-xxxxx.pooler.supabase.com:6543/postgres

# ========================================
# 🤖 AI CONFIGURATION (OPTIONAL)
# ========================================

# Google Gemini AI
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# App URL (used for redirects, OAuth callbacks)
APP_URL=http://localhost:3000

# ========================================
# 📱 FIREBASE (LEGACY - Optional)
# ========================================
# These are optional if you still have Firebase dependencies

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
